{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "frontend/**" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "env": {
    "DATABASE_URL": "sqlite:////tmp/catalog.db",
    "UPLOAD_DIR": "/tmp/uploads"
  }
}
